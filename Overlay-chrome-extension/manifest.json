{

  "manifest_version": 3,

  "name": "Overlay MatchTimer",

  "version": "1.0.0",

  "description": "Professional match analysis overlay for Xeatre, Inplayip & Examino streams. Drift-proof timer, frame scrubbing, ShuttleXpress hardware support & smart docked controls.",

  "author": "Vasco Oliveira",



  "permissions": [

    "storage"

  ],



  "host_permissions": [
    "*://*.inplayip.tv/*",
    "file:///*",
    "*://statsperform.media.xeatre.cloud/*",
    "*://examino.statsperform.io/play/dvr/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.inplayip.tv/*",
        "file:///*",
        "*://statsperform.media.xeatre.cloud/*",
        "*://examino.statsperform.io/play/dvr/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]

} 

